<?xml version="1.0" encoding="utf-8"?>
<workout_file>
    <name>Mixed Workout Test</name>
    <author>Test</author>
    <description>Warmup, intervals, free ride, cooldown</description>
    <workout>
        <Warmup     Duration="600"  PowerLow="0.40" PowerHigh="0.75"/>
        <SteadyState Duration="300" Power="0.75"/>
        <IntervalsT Repeat="3" OnDuration="120" OffDuration="60" OnPower="1.15" OffPower="0.50"/>
        <FreeRide   Duration="600"/>
        <Cooldown   Duration="600"  PowerLow="0.75" PowerHigh="0.40"/>
    </workout>
</workout_file>
